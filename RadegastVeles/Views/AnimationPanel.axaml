<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:Radegast.Veles.ViewModels"
             xmlns:views="using:Radegast.Veles.Views"
             x:Class="Radegast.Veles.Views.AnimationPanel"
             x:DataType="vm:AnimationViewModel"
             AutomationProperties.Name="Animation viewer">
    <DockPanel>

        <!-- Toolbar -->
        <Border DockPanel.Dock="Top" BorderThickness="0,0,0,1" Padding="4,2">
            <WrapPanel Orientation="Horizontal" VerticalAlignment="Center">
                <TextBlock Text="{Binding AnimationName}" FontWeight="SemiBold" VerticalAlignment="Center"
                           Margin="0,0,8,0" AutomationProperties.Name="Animation name" />
                <Button Command="{Binding TogglePlayCommand}" Margin="0,0,4,0" MinWidth="96"
                        AutomationProperties.Name="Toggle animation playback">
                    <StackPanel Orientation="Horizontal" Spacing="4">
                        <TextBlock Text="&#x23F9; Stop" IsVisible="{Binding IsPlaying}" AutomationProperties.Name="Stop animation" />
                        <TextBlock Text="&#x25B6; Play" IsVisible="{Binding !IsPlaying}" AutomationProperties.Name="Play animation" />
                    </StackPanel>
                </Button>
                <Button Content="&#x1F4BE; Save…" Command="{Binding SaveCommand}"
                        Margin="0,0,8,0" MinWidth="80"
                        AutomationProperties.Name="Save animation to disk" />
                <Button x:Name="BtnDetach" Content="&#x23CF; Detach" Margin="0,0,4,0" MinWidth="72"
                        AutomationProperties.Name="Detach animation viewer" />
                <Button x:Name="BtnClose" Content="&#x2715; Close" Margin="0,0,4,0" MinWidth="64"
                        AutomationProperties.Name="Close animation viewer" />
            </WrapPanel>
        </Border>

        <!-- Status bar -->
        <Grid DockPanel.Dock="Bottom" ColumnDefinitions="*,Auto" Margin="4,2">
            <TextBlock Grid.Column="0" Text="{Binding StatusText}" VerticalAlignment="Center"
                       AutomationProperties.Name="Animation status" />
            <ProgressBar Grid.Column="1" IsVisible="{Binding IsLoading}" IsIndeterminate="True"
                         Width="80" Height="8" VerticalAlignment="Center"
                         AutomationProperties.Name="Loading indicator" />
        </Grid>

        <ContentControl DockPanel.Dock="Bottom" Content="{Binding Metadata}">
            <ContentControl.ContentTemplate>
                <DataTemplate x:DataType="vm:ItemMetadataViewModel">
                    <views:ItemMetadataPanel />
                </DataTemplate>
            </ContentControl.ContentTemplate>
        </ContentControl>

        <!-- Center content -->
        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Spacing="12">
            <TextBlock Text="&#x1F3AC;" FontSize="48" HorizontalAlignment="Center"
                       AutomationProperties.Name="Animation icon" />
            <TextBlock Text="{Binding AnimationName}" FontSize="14" HorizontalAlignment="Center"
                       TextWrapping="Wrap" AutomationProperties.Name="Animation name label" />
            <TextBlock Text="{Binding DataSizeText}"
                       IsVisible="{Binding DataSizeText, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"
                       HorizontalAlignment="Center" Opacity="0.7"
                       AutomationProperties.Name="Animation data size" />
            <TextBlock IsVisible="{Binding IsPlaying}" Text="▶ Playing inworld…"
                       Foreground="#FF107C10" HorizontalAlignment="Center"
                       AutomationProperties.Name="Playing indicator" />
        </StackPanel>

    </DockPanel>
</UserControl>
