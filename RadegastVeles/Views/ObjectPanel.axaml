<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:Radegast.Veles.ViewModels"
             xmlns:views="using:Radegast.Veles.Views"
             x:Class="Radegast.Veles.Views.ObjectPanel"
             x:DataType="vm:ObjectViewModel"
             AutomationProperties.Name="Object viewer">
    <DockPanel>

        <!-- Toolbar -->
        <Border DockPanel.Dock="Top" BorderThickness="0,0,0,1" Padding="4,2">
            <WrapPanel Orientation="Horizontal" VerticalAlignment="Center">
                <TextBlock Text="{Binding ObjectName}" FontWeight="SemiBold" VerticalAlignment="Center"
                           Margin="0,0,8,0" AutomationProperties.Name="Object name" />
                <Button Content="&#x1F4CE; Attach" Command="{Binding AttachCommand}"
                        IsVisible="{Binding !IsAttached}"
                        Margin="0,0,4,0" MinWidth="80"
                        AutomationProperties.Name="Attach this object" />
                <Button Content="&#x274C; Detach" Command="{Binding DetachCommand}"
                        IsVisible="{Binding IsAttached}"
                        Margin="0,0,8,0" MinWidth="80"
                        AutomationProperties.Name="Detach this object" />
                <Button x:Name="BtnDetach" Content="&#x23CF; Detach" Margin="0,0,4,0" MinWidth="72"
                        AutomationProperties.Name="Detach object viewer to window" />
                <Button x:Name="BtnClose" Content="&#x2715; Close" Margin="0,0,4,0" MinWidth="64"
                        AutomationProperties.Name="Close object viewer" />
            </WrapPanel>
        </Border>

        <!-- Status bar -->
        <TextBlock DockPanel.Dock="Bottom" Text="{Binding StatusText}" Margin="4,2"
                   VerticalAlignment="Center" AutomationProperties.Name="Object status" />

        <!-- Metadata panel (creator, UUIDs, etc.) -->
        <ContentControl DockPanel.Dock="Bottom" Content="{Binding Metadata}">
            <ContentControl.ContentTemplate>
                <DataTemplate x:DataType="vm:ItemMetadataViewModel">
                    <views:ItemMetadataPanel />
                </DataTemplate>
            </ContentControl.ContentTemplate>
        </ContentControl>

        <!-- Scrollable main content -->
        <ScrollViewer HorizontalScrollBarVisibility="Disabled" VerticalScrollBarVisibility="Auto">
            <StackPanel Spacing="0" Margin="12,8">

                <!-- Header row: icon + name + type badge -->
                <StackPanel Orientation="Horizontal" Spacing="12" Margin="0,0,0,10">
                    <TextBlock Text="&#x1F4E6;" FontSize="40" VerticalAlignment="Center"
                               AutomationProperties.Name="Object icon" />
                    <StackPanel VerticalAlignment="Center" Spacing="2">
                        <TextBlock Text="{Binding ObjectName}" FontSize="14" FontWeight="SemiBold"
                                   TextWrapping="Wrap" AutomationProperties.Name="Object name label" />
                        <StackPanel Orientation="Horizontal" Spacing="6">
                            <Border Background="#555" CornerRadius="3" Padding="5,2">
                                <TextBlock Text="{Binding ItemTypeName}" FontSize="11" Foreground="White"
                                           AutomationProperties.Name="Item type" />
                            </Border>
                            <Border Background="#1565C0" CornerRadius="3" Padding="5,2"
                                    IsVisible="{Binding IsHudObject}">
                                <TextBlock Text="HUD" FontSize="11" Foreground="White"
                                           ToolTip.Tip="This is a HUD attachment" />
                            </Border>
                            <Border Background="#6A1B9A" CornerRadius="3" Padding="5,2"
                                    IsVisible="{Binding IsCoalesced}">
                                <TextBlock Text="Coalesced" FontSize="11" Foreground="White"
                                           ToolTip.Tip="Contains multiple objects" />
                            </Border>
                            <Border Background="#558B2F" CornerRadius="3" Padding="5,2"
                                    IsVisible="{Binding IsForSale}">
                                <TextBlock Text="For Sale" FontSize="11" Foreground="White"
                                           ToolTip.Tip="{Binding SaleText}" />
                            </Border>
                            <Border Background="#E65100" CornerRadius="3" Padding="5,2"
                                    IsVisible="{Binding IsGroupOwned}">
                                <TextBlock Text="Group" FontSize="11" Foreground="White"
                                           ToolTip.Tip="Group-owned item" />
                            </Border>
                        </StackPanel>
                    </StackPanel>
                </StackPanel>

                <!-- Description -->
                <Border IsVisible="{Binding HasDescription}" Margin="0,0,0,10"
                        Background="#11808080" CornerRadius="4" Padding="8,6">
                    <TextBlock Text="{Binding Description}" TextWrapping="Wrap"
                               FontStyle="Italic" Opacity="0.85"
                               AutomationProperties.Name="Description" />
                </Border>

                <!-- Attachment info -->
                <Border BorderThickness="0,0,0,1" Margin="0,0,0,8" Padding="0,0,0,8">
                    <Grid ColumnDefinitions="120,*" RowDefinitions="Auto,Auto,Auto">
                        <TextBlock Grid.Row="0" Grid.Column="0" Text="Default Point:" FontWeight="SemiBold"
                                   VerticalAlignment="Center" />
                        <StackPanel Grid.Row="0" Grid.Column="1" Orientation="Horizontal" Spacing="6"
                                    VerticalAlignment="Center">
                            <TextBlock Text="{Binding AttachPointText}"
                                       AutomationProperties.Name="Default attach point" />
                            <Border Background="#1565C0" CornerRadius="3" Padding="4,1"
                                    IsVisible="{Binding IsHudObject}">
                                <TextBlock Text="HUD" FontSize="10" Foreground="White" />
                            </Border>
                        </StackPanel>

                        <TextBlock Grid.Row="1" Grid.Column="0" Text="Zone:" FontWeight="SemiBold"
                                   VerticalAlignment="Center" Margin="0,4,0,0" />
                        <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding AttachZoneText}"
                                   VerticalAlignment="Center" Margin="0,4,0,0"
                                   AutomationProperties.Name="Attach zone" />

                        <TextBlock Grid.Row="2" Grid.Column="0" Text="Sale:" FontWeight="SemiBold"
                                   VerticalAlignment="Center" Margin="0,4,0,0"
                                   IsVisible="{Binding IsForSale}" />
                        <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding SaleText}"
                                   VerticalAlignment="Center" Margin="0,4,0,0"
                                   IsVisible="{Binding IsForSale}"
                                   AutomationProperties.Name="Sale info" />
                    </Grid>
                </Border>

                <!-- Permission grid -->
                <TextBlock Text="Permissions" FontWeight="SemiBold" Margin="0,0,0,6"
                           AutomationProperties.Name="Permissions heading" />
                <Grid ColumnDefinitions="100,*" RowDefinitions="Auto,Auto,Auto,Auto"
                      Margin="0,0,0,10">
                    <TextBlock Grid.Row="0" Grid.Column="0" Text="Owner:" FontWeight="SemiBold"
                               VerticalAlignment="Center" Margin="0,3,8,3" />
                    <views:PermissionBadgesControl Grid.Row="0" Grid.Column="1"
                               NoModify="{Binding OwnerNoModify}"
                               NoCopy="{Binding OwnerNoCopy}"
                               NoTransfer="{Binding OwnerNoTransfer}"
                               VerticalAlignment="Center"
                               AutomationProperties.Name="Owner permissions" />

                    <TextBlock Grid.Row="1" Grid.Column="0" Text="Next Owner:" FontWeight="SemiBold"
                               VerticalAlignment="Center" Margin="0,3,8,3" />
                    <views:PermissionBadgesControl Grid.Row="1" Grid.Column="1"
                               NoModify="{Binding NextNoModify}"
                               NoCopy="{Binding NextNoCopy}"
                               NoTransfer="{Binding NextNoTransfer}"
                               VerticalAlignment="Center"
                               AutomationProperties.Name="Next owner permissions" />

                    <TextBlock Grid.Row="2" Grid.Column="0" Text="Group:" FontWeight="SemiBold"
                               VerticalAlignment="Center" Margin="0,3,8,3" />
                    <views:PermissionBadgesControl Grid.Row="2" Grid.Column="1"
                               NoModify="{Binding GroupNoModify}"
                               NoCopy="{Binding GroupNoCopy}"
                               NoTransfer="{Binding GroupNoTransfer}"
                               VerticalAlignment="Center"
                               AutomationProperties.Name="Group permissions" />

                    <TextBlock Grid.Row="3" Grid.Column="0" Text="Everyone:" FontWeight="SemiBold"
                               VerticalAlignment="Center" Margin="0,3,8,3" />
                    <views:PermissionBadgesControl Grid.Row="3" Grid.Column="1"
                               NoModify="{Binding EveryoneNoModify}"
                               NoCopy="{Binding EveryoneNoCopy}"
                               NoTransfer="{Binding EveryoneNoTransfer}"
                               VerticalAlignment="Center"
                               AutomationProperties.Name="Everyone permissions" />
                </Grid>

                <!-- Slam warnings -->
                <StackPanel Spacing="4" Margin="0,0,0,8">
                    <Border Background="#CC6600" CornerRadius="4" Padding="8,4"
                            IsVisible="{Binding HasSlamPerm}" HorizontalAlignment="Left">
                        <TextBlock Text="&#x26A0; Permissions will be overwritten on rez"
                                   Foreground="White" FontSize="11"
                                   AutomationProperties.Name="Permission slam warning" />
                    </Border>
                    <Border Background="#CC6600" CornerRadius="4" Padding="8,4"
                            IsVisible="{Binding HasSlamSale}" HorizontalAlignment="Left">
                        <TextBlock Text="&#x26A0; Sale settings will be overwritten on rez"
                                   Foreground="White" FontSize="11"
                                   AutomationProperties.Name="Sale slam warning" />
                    </Border>
                </StackPanel>

                <!-- Attachment state badge -->
                <Border Background="#FF107C10" CornerRadius="4" Padding="8,4"
                        IsVisible="{Binding IsAttached}" HorizontalAlignment="Left">
                    <StackPanel Orientation="Horizontal" Spacing="6">
                        <TextBlock Text="&#x1F4CC; Attached at" Foreground="White" FontWeight="SemiBold" />
                        <TextBlock Text="{Binding CurrentAttachPointText}" Foreground="White" FontWeight="SemiBold"
                                   AutomationProperties.Name="Current attach point" />
                    </StackPanel>
                </Border>

            </StackPanel>
        </ScrollViewer>

    </DockPanel>
</UserControl>

