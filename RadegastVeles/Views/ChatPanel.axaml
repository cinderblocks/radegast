<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:Radegast.Veles.ViewModels"
             xmlns:controls="using:Radegast.Veles.Controls"
             x:Class="Radegast.Veles.Views.ChatPanel"
             x:DataType="vm:NearbyViewModel"
             AutomationProperties.Name="Chat panel">

    <Grid ColumnDefinitions="*,8,260">
        <!-- Left: Chat area -->
        <DockPanel Grid.Column="0">
            <!-- Chat input -->
            <Grid DockPanel.Dock="Bottom" ColumnDefinitions="Auto,*,Auto" Margin="4" AutomationProperties.Name="Chat input area">

                <ComboBox Grid.Column="0" ItemsSource="{Binding ChatTypes}" SelectedIndex="{Binding SelectedChatTypeIndex}" MinWidth="90" VerticalAlignment="Stretch" AutomationProperties.Name="Chat type selector" AutomationProperties.HelpText="Select Whisper, Normal, or Shout. Shift+Enter whispers, Ctrl+Enter shouts." />
                <TextBox Grid.Column="1" x:Name="ChatInputBox" Text="{Binding ChatInput, Mode=TwoWay}" PlaceholderText="Type a message..." Margin="4,0" VerticalAlignment="Center" AutomationProperties.Name="Chat message input" AutomationProperties.HelpText="Type your message and press Enter to send" />
                <Button Grid.Column="2" Content="Send" Command="{Binding SendChatCommand}" MinWidth="60" VerticalAlignment="Stretch" AutomationProperties.Name="Send chat message" />
            </Grid>

            <!-- History indicator: appears when earlier messages exist above the current view -->
            <Grid DockPanel.Dock="Top"
                  IsVisible="{Binding HasPrecedingHistory}"
                  Margin="4,4,4,0"
                  AutomationProperties.Name="Chat history indicator">
                <TextBlock IsVisible="{Binding !IsLoadingHistory}"
                           Text="▲  Earlier messages · scroll up to load more"
                           HorizontalAlignment="Center" FontSize="11" Opacity="0.6"
                           AutomationProperties.Name="Earlier messages available above" />
                <StackPanel IsVisible="{Binding IsLoadingHistory}"
                            Orientation="Horizontal" HorizontalAlignment="Center" Spacing="6">
                    <ProgressBar IsIndeterminate="True" Width="40" Height="3" VerticalAlignment="Center" />
                    <TextBlock Text="Loading earlier messages…"
                               FontSize="11" Opacity="0.6" VerticalAlignment="Center" />
                </StackPanel>
            </Grid>

            <!-- Chat log -->
            <ListBox x:Name="ChatLog" ItemsSource="{Binding ChatLines}" Margin="4,4,4,0" AutomationProperties.Name="Chat message history" AutomationProperties.LiveSetting="Polite" ScrollViewer.HorizontalScrollBarVisibility="Disabled" SelectionMode="Multiple,Toggle">
                <ListBox.Styles>
                    <Style Selector="Button.chatName">
                        <Setter Property="Background" Value="Transparent" />
                        <Setter Property="BorderThickness" Value="0" />
                        <Setter Property="Padding" Value="0" />
                        <Setter Property="Cursor" Value="Hand" />
                        <Setter Property="MinWidth" Value="0" />
                        <Setter Property="MinHeight" Value="0" />
                    </Style>
                    <Style Selector="Button.chatName:pointerover /template/ ContentPresenter#PART_ContentPresenter">
                        <Setter Property="Background" Value="Transparent" />
                    </Style>
                    <Style Selector="Button.chatName TextBlock">
                        <Setter Property="TextDecorations" Value="Underline" />
                    </Style>
                </ListBox.Styles>
                <ListBox.ItemTemplate>
                    <DataTemplate x:DataType="vm:ChatLine">
                        <Grid AutomationProperties.Name="{Binding AutomationText}">
                            <!-- Date-change separator -->
                            <Grid IsVisible="{Binding IsDateSeparator}"
                                  ColumnDefinitions="*,Auto,*"
                                  Margin="4,6,4,4"
                                  AutomationProperties.Name="{Binding DateLabel}">
                                <Border Grid.Column="0" Height="1" VerticalAlignment="Center"
                                        Background="Gray" Opacity="0.3" Margin="0,0,8,0" />
                                <TextBlock Grid.Column="1" Text="{Binding DateLabel}"
                                           FontSize="11" Opacity="0.5" VerticalAlignment="Center" />
                                <Border Grid.Column="2" Height="1" VerticalAlignment="Center"
                                        Background="Gray" Opacity="0.3" Margin="8,0,0,0" />
                            </Grid>

                            <!-- Normal message row -->
                            <WrapPanel IsVisible="{Binding !IsDateSeparator}"
                                       AutomationProperties.Name="{Binding AutomationText}"
                                       Opacity="{Binding HistoryOpacity}"
                                       ContextRequested="OnChatLineContextRequested">
                                <TextBlock Text="{Binding FormattedTime}" Opacity="0.6" Margin="0,0,4,0" />

                                <!-- Emote row: * Name action text * in italic, no separator link -->
                                <Button Classes="chatName" Click="OnChatNameClick" ContextRequested="OnChatNameContextRequested" Tag="{Binding}"
                                        IsVisible="{Binding IsEmote}"
                                        AutomationProperties.Name="{Binding From, StringFormat=Open profile for {0}}">
                                    <TextBlock Text="{Binding EmoteDisplayText}"
                                               FontStyle="Italic"
                                               Foreground="#AA88CC" />
                                </Button>

                                <!-- Normal / Self / Object rows -->
                                <Button Classes="chatName" Click="OnChatNameClick" ContextRequested="OnChatNameContextRequested" Tag="{Binding}"
                                        IsVisible="{Binding HasNonEmoteAgentLink}"
                                        AutomationProperties.Name="{Binding From, StringFormat=Open profile for {0}}">
                                    <TextBlock Text="{Binding From}" FontWeight="SemiBold" />
                                </Button>
                                <Button Classes="chatName" Click="OnChatObjectClick" ContextRequested="OnChatObjectContextRequested" Tag="{Binding}"
                                        IsVisible="{Binding HasObjectLink}"
                                        AutomationProperties.Name="{Binding From, StringFormat=Object: {0}}">
                                    <TextBlock Text="{Binding From}" FontWeight="SemiBold" />
                                </Button>
                                <TextBlock Text="{Binding From}" FontWeight="SemiBold"
                                           IsVisible="{Binding ShowStaticName}" />
                                <controls:RichChatText Text="{Binding Text}"
                                                       IsVisible="{Binding ShowNamePrefix}" />
                            </WrapPanel>
                        </Grid>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>
        </DockPanel>

        <!-- Splitter -->
        <GridSplitter Grid.Column="1" ResizeDirection="Columns" Background="Transparent" AutomationProperties.Name="Resize panel splitter" />

        <!-- Right panel -->
        <DockPanel Grid.Column="2">
            <!-- Minimap -->
            <Border DockPanel.Dock="Top" Padding="4,4,4,0" IsVisible="{Binding IsMinimapVisible}" AutomationProperties.Name="Minimap area">
                <StackPanel Spacing="2">
                    <TextBlock Text="Minimap" FontWeight="SemiBold" FontSize="11" />
                    <controls:MinimapControl x:Name="Minimap" Entries="{Binding MinimapEntries}" BackgroundImage="{Binding MinimapTile}"
                                             SelectedEntryId="{Binding SelectedMinimapEntryId}"
                                             SimName="{Binding RegionName}"
                                             Width="200" Height="200" HorizontalAlignment="Center" />
                </StackPanel>
            </Border>

            <!-- Movement controls (compact) -->
            <Border DockPanel.Dock="Top" Padding="4,4,4,2" AutomationProperties.Name="Movement controls">
                <Border.Styles>
                    <!-- Pressed visual: accent fill + white glyph while the button is held down -->
                    <Style Selector="Button.movementBtn:pressed /template/ ContentPresenter#PART_ContentPresenter">
                        <Setter Property="Background" Value="#2B6CB0" />
                    </Style>
                    <Style Selector="Button.movementBtn:pressed">
                        <Setter Property="Foreground" Value="White" />
                    </Style>
                </Border.Styles>
                <StackPanel Spacing="2">
                    <Grid ColumnDefinitions="32,2,32,2,32" RowDefinitions="28,2,28" HorizontalAlignment="Center">
                        <Button x:Name="BtnForward"  Classes="movementBtn" Grid.Row="0" Grid.Column="2" Content="&#x25B2;" Width="32" Height="28" Padding="0" HorizontalContentAlignment="Center" AutomationProperties.Name="Move forward" />
                        <Button x:Name="BtnLeft"     Classes="movementBtn" Grid.Row="2" Grid.Column="0" Content="&#x25C0;" Width="32" Height="28" Padding="0" HorizontalContentAlignment="Center" AutomationProperties.Name="Turn left" />
                        <Button x:Name="BtnBackward" Classes="movementBtn" Grid.Row="2" Grid.Column="2" Content="&#x25BC;" Width="32" Height="28" Padding="0" HorizontalContentAlignment="Center" AutomationProperties.Name="Move backward" />
                        <Button x:Name="BtnRight"    Classes="movementBtn" Grid.Row="2" Grid.Column="4" Content="&#x25B6;" Width="32" Height="28" Padding="0" HorizontalContentAlignment="Center" AutomationProperties.Name="Turn right" />
                    </Grid>
                    <WrapPanel HorizontalAlignment="Center" Orientation="Horizontal">
                        <Button x:Name="BtnJump"   Classes="movementBtn" Content="Jump"  Margin="2,1" MinWidth="44" Padding="4,2" AutomationProperties.Name="Jump" />
                        <Button x:Name="BtnCrouch" Classes="movementBtn" Content="Crouch" Margin="2,1" MinWidth="44" Padding="4,2" AutomationProperties.Name="Crouch" />
                        <ToggleButton Content="Fly" IsChecked="{Binding IsFlying}"  Command="{Binding ToggleFlyCommand}"  Margin="2,1" MinWidth="44" Padding="4,2" AutomationProperties.Name="Toggle flying" />
                        <ToggleButton Content="Run" IsChecked="{Binding IsRunning}" Command="{Binding ToggleRunCommand}" Margin="2,1" MinWidth="44" Padding="4,2" AutomationProperties.Name="Toggle running" />
                        <ToggleButton Content="{Binding SitOnGroundLabel}" IsChecked="{Binding IsSittingOnGround}" Command="{Binding ToggleSitOnGroundCommand}" Margin="2,1" MinWidth="44" Padding="4,2" AutomationProperties.Name="Toggle sit on ground" />
                    </WrapPanel>
                </StackPanel>
            </Border>

            <!-- Media controls + Now Playing ticker -->
            <Border DockPanel.Dock="Bottom" Padding="4,3,4,3"
                    IsVisible="{Binding IsMediaAvailable}"
                    AutomationProperties.Name="Media controls">
                <StackPanel Orientation="Horizontal" Spacing="4">
                    <Button Content="&#x25B6;" Command="{Binding PlayStreamCommand}"
                            IsVisible="{Binding !IsStreamPlaying}"
                            MinWidth="20" MinHeight="16" Padding="3,0" FontSize="10"
                            ToolTip.Tip="Play stream"
                            AutomationProperties.Name="Play stream" />
                    <Button Content="&#x23F8;" Command="{Binding StopStreamCommand}"
                            IsVisible="{Binding IsStreamPlaying}"
                            MinWidth="20" MinHeight="16" Padding="3,0" FontSize="10"
                            ToolTip.Tip="Stop stream"
                            AutomationProperties.Name="Stop stream" />
                    <TextBlock Text="&#x266B;" FontSize="11" Opacity="0.6" VerticalAlignment="Center"
                               IsVisible="{Binding IsStreamPlaying}" />
                    <TextBlock Text="{Binding NowPlayingText}" FontSize="11"
                               TextTrimming="CharacterEllipsis"
                               VerticalAlignment="Center"
                               ToolTip.Tip="{Binding NowPlayingText}"
                               IsVisible="{Binding IsStreamPlaying}"
                               AutomationProperties.Name="Now playing text" />
                </StackPanel>
            </Border>

            <!-- Nearby avatars -->
            <Border Padding="4,2,4,4" AutomationProperties.Name="Nearby avatars area">
                <DockPanel>
                    <TextBlock DockPanel.Dock="Top" Text="Nearby" FontWeight="SemiBold" Margin="0,0,0,2" />

                    <!-- Sim permission / health status bar -->
                    <WrapPanel DockPanel.Dock="Top" Orientation="Horizontal" Margin="0,0,0,4"
                               AutomationProperties.Name="Sim status"
                               AutomationProperties.LiveSetting="Polite">
                        <!-- Health: ♥ + percentage, shown only when damage is enabled -->
                        <StackPanel Orientation="Horizontal" Spacing="2"
                                    IsVisible="{Binding IsDamageEnabled}"
                                    ToolTip.Tip="Avatar health"
                                    AutomationProperties.Name="{Binding HealthAccessibleText}"
                                    Margin="0,0,6,0">
                            <TextBlock Text="♥" Foreground="#CC2222" FontSize="12" VerticalAlignment="Center" AutomationProperties.Name="" />
                            <TextBlock Text="{Binding Health, StringFormat='{}{0:0}%'}" FontSize="11"
                                       Foreground="#CC2222" VerticalAlignment="Center" AutomationProperties.Name="" />
                        </StackPanel>

                        <!-- Fly -->
                        <TextBlock Text="✈" FontSize="13" Foreground="#44BB44"
                                   IsVisible="{Binding CanFly}"
                                   ToolTip.Tip="Flying allowed"
                                   AutomationProperties.Name="Flying allowed"
                                   Margin="0,0,6,0" />
                        <TextBlock Text="✈" FontSize="13" Foreground="#CC2222"
                                   IsVisible="{Binding !CanFly}"
                                   ToolTip.Tip="Flying not allowed"
                                   AutomationProperties.Name="Flying not allowed"
                                   Margin="0,0,6,0" />

                        <!-- Build -->
                        <TextBlock Text="⚒" FontSize="13" Foreground="#44BB44"
                                   IsVisible="{Binding CanBuild}"
                                   ToolTip.Tip="Building allowed"
                                   AutomationProperties.Name="Building allowed"
                                   Margin="0,0,6,0" />
                        <TextBlock Text="⚒" FontSize="13" Foreground="#CC2222"
                                   IsVisible="{Binding !CanBuild}"
                                   ToolTip.Tip="Building not allowed"
                                   AutomationProperties.Name="Building not allowed"
                                   Margin="0,0,6,0" />

                        <!-- Scripts -->
                        <TextBlock Text="⚙" FontSize="13" Foreground="#44BB44"
                                   IsVisible="{Binding ScriptsAllowed}"
                                   ToolTip.Tip="Scripts allowed"
                                   AutomationProperties.Name="Scripts allowed"
                                   Margin="0,0,6,0" />
                        <TextBlock Text="⚙" FontSize="13" Foreground="#CC2222"
                                   IsVisible="{Binding !ScriptsAllowed}"
                                   ToolTip.Tip="Scripts not allowed"
                                   AutomationProperties.Name="Scripts not allowed"
                                   Margin="0,0,6,0" />

                        <!-- Push -->
                        <TextBlock Text="↑" FontSize="13" Foreground="#44BB44"
                                   IsVisible="{Binding PushAllowed}"
                                   ToolTip.Tip="Avatar push allowed"
                                   AutomationProperties.Name="Avatar push allowed"
                                   Margin="0,0,6,0" />
                        <TextBlock Text="↑" FontSize="13" Foreground="#CC2222"
                                   IsVisible="{Binding !PushAllowed}"
                                   ToolTip.Tip="Avatar push restricted"
                                   AutomationProperties.Name="Avatar push restricted"
                                   Margin="0,0,6,0" />

                        <!-- Voice -->
                        <TextBlock Text="♪" FontSize="13" Foreground="#44BB44"
                                   IsVisible="{Binding VoiceAllowed}"
                                   ToolTip.Tip="Voice chat allowed"
                                   AutomationProperties.Name="Voice chat allowed" />
                        <TextBlock Text="♪" FontSize="13" Foreground="#CC2222"
                                   IsVisible="{Binding !VoiceAllowed}"
                                   ToolTip.Tip="Voice chat not allowed"
                                   AutomationProperties.Name="Voice chat not allowed" />
                    </WrapPanel>

                    <TabControl AutomationProperties.Name="Nearby and radar history tabs">
                        <TabControl.Styles>
                            <Style Selector="Button.nearbyName">
                                <Setter Property="Background" Value="Transparent" />
                                <Setter Property="BorderThickness" Value="0" />
                                <Setter Property="Padding" Value="2,1" />
                                <Setter Property="Cursor" Value="Hand" />
                                <Setter Property="MinWidth" Value="0" />
                                <Setter Property="MinHeight" Value="0" />
                                <Setter Property="HorizontalAlignment" Value="Stretch" />
                                <Setter Property="HorizontalContentAlignment" Value="Left" />
                            </Style>
                            <Style Selector="Button.nearbyName:pointerover /template/ ContentPresenter#PART_ContentPresenter">
                                <Setter Property="Background" Value="Transparent" />
                            </Style>
                            <Style Selector="Button.nearbyName TextBlock">
                                <Setter Property="TextDecorations" Value="Underline" />
                            </Style>
                        </TabControl.Styles>
                        <TabItem Header="Nearby" AutomationProperties.Name="Nearby avatars">
                            <ListBox ItemsSource="{Binding NearbyAvatars}" SelectedItem="{Binding SelectedNearbyAvatar, Mode=TwoWay}" AutomationProperties.Name="Nearby avatars list" AutomationProperties.LiveSetting="Polite" ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                                <ListBox.ItemTemplate>
                                    <DataTemplate x:DataType="vm:NearbyAvatar">
                                        <WrapPanel VerticalAlignment="Center"
                                                   AutomationProperties.Name="{Binding AccessibleText}">
                                            <Button Classes="nearbyName" Click="OnNearbyAvatarClick" ContextRequested="OnNearbyContextRequested" Tag="{Binding}"
                                                    IsEnabled="{Binding !IsSelf}"
                                                    AutomationProperties.Name="{Binding DisplayText, StringFormat=Open profile for {0}}">
                                                <TextBlock Text="{Binding DisplayText}" TextWrapping="NoWrap" TextTrimming="CharacterEllipsis" AutomationProperties.Name="" />
                                            </Button>
                                            <!-- Status icons: visible for sighted users, silenced for screen readers (AccessibleText has the combined description) -->
                                            <TextBlock Text="{Binding VoiceIcon}"
                                                       IsVisible="{Binding ShowVoiceIcon}"
                                                       FontSize="11" VerticalAlignment="Center"
                                                       Margin="3,0,0,0" ToolTip.Tip="In voice channel"
                                                       AutomationProperties.Name="" />
                                            <TextBlock Text="{Binding TypingIcon}"
                                                       IsVisible="{Binding ShowTypingIcon}"
                                                       FontSize="11" VerticalAlignment="Center"
                                                       Margin="3,0,0,0" ToolTip.Tip="Typing"
                                                       AutomationProperties.Name="" />
                                            <TextBlock Text="{Binding AwayIcon}"
                                                       IsVisible="{Binding ShowAwayIcon}"
                                                       FontSize="11" VerticalAlignment="Center"
                                                       Margin="3,0,0,0" ToolTip.Tip="Away"
                                                       AutomationProperties.Name="" />
                                            <TextBlock Text="{Binding BusyIcon}"
                                                       IsVisible="{Binding ShowBusyIcon}"
                                                       FontSize="11" VerticalAlignment="Center"
                                                       Margin="3,0,0,0" ToolTip.Tip="Busy / Do Not Disturb"
                                                       AutomationProperties.Name="" />
                                            <TextBlock Text="{Binding FlyingIcon}"
                                                       IsVisible="{Binding ShowFlyingIcon}"
                                                       FontSize="11" VerticalAlignment="Center"
                                                       Margin="3,0,0,0" ToolTip.Tip="Flying"
                                                       AutomationProperties.Name="" />
                                            <TextBlock Text="{Binding SittingIcon}"
                                                       IsVisible="{Binding ShowSittingIcon}"
                                                       FontSize="11" VerticalAlignment="Center"
                                                       Margin="3,0,0,0" ToolTip.Tip="Sitting"
                                                       AutomationProperties.Name="" />
                                        </WrapPanel>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>
                        </TabItem>
                        <TabItem Header="History" AutomationProperties.Name="Radar history">
                            <DockPanel>
                                <Button DockPanel.Dock="Bottom"
                                        Content="Clear"
                                        Command="{Binding ClearRadarHistoryCommand}"
                                        HorizontalAlignment="Right"
                                        Margin="0,4,0,0"
                                        Padding="8,2"
                                        AutomationProperties.Name="Clear radar history" />
                                <ListBox ItemsSource="{Binding RadarHistory}"
                                         ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                         AutomationProperties.Name="Radar history list">
                                    <ListBox.ItemTemplate>
                                        <DataTemplate x:DataType="vm:RadarHistoryEntry">
                                            <Grid ColumnDefinitions="*,Auto">
                                                <Button Classes="nearbyName" Grid.Column="0"
                                                        Click="OnHistoryAvatarClick"
                                                        ContextRequested="OnHistoryContextRequested"
                                                        Tag="{Binding}"
                                                        ToolTip.Tip="{Binding Name}"
                                                        AutomationProperties.Name="{Binding Name, StringFormat='Open profile for {0}'}">
                                                    <TextBlock Text="{Binding Name}"
                                                               TextTrimming="CharacterEllipsis"
                                                               FontSize="11"
                                                               AutomationProperties.Name="" />
                                                </Button>
                                                <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="4" Margin="4,0,0,0"
                                                            VerticalAlignment="Center">
                                                    <TextBlock Text="{Binding ClosestDistanceText}"
                                                               FontSize="10"
                                                               Foreground="{DynamicResource VelesMutedForeground}"
                                                               VerticalAlignment="Center"
                                                               ToolTip.Tip="Closest distance"
                                                               AutomationProperties.Name="" />
                                                    <TextBlock Text="{Binding LastSeenText}"
                                                               FontSize="10"
                                                               Foreground="{DynamicResource VelesMutedForeground}"
                                                               VerticalAlignment="Center"
                                                               ToolTip.Tip="Last seen"
                                                               AutomationProperties.Name="" />
                                                </StackPanel>
                                            </Grid>
                                        </DataTemplate>
                                    </ListBox.ItemTemplate>
                                </ListBox>
                            </DockPanel>
                        </TabItem>
                    </TabControl>
                </DockPanel>
            </Border>
        </DockPanel>
    </Grid>
</UserControl>
