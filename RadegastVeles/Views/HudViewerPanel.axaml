<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:Radegast.Veles.ViewModels"
             xmlns:rendering="using:Radegast.Veles.Rendering"
             x:Class="Radegast.Veles.Views.HudViewerPanel"
             x:DataType="vm:HudViewerViewModel"
             AutomationProperties.Name="HUD viewer">

    <Grid ColumnDefinitions="Auto,Auto,*">

        <!-- Left: HUD attachment list -->
        <Border Grid.Column="0" Width="200" BorderThickness="0,0,1,0" Padding="4"
                IsVisible="{Binding IsHudListVisible}">
            <DockPanel>
                <TextBlock DockPanel.Dock="Top" Text="HUD Attachments"
                           FontWeight="SemiBold" Margin="0,0,0,4"
                           AutomationProperties.Name="HUD attachments header" />
                <Button DockPanel.Dock="Bottom" Content="&#x27F3; Refresh"
                        Command="{Binding RefreshCommand}"
                        HorizontalAlignment="Stretch" Margin="0,4,0,0"
                        AutomationProperties.Name="Refresh HUD list" />

                <ListBox ItemsSource="{Binding HudAttachments}"
                         SelectedItem="{Binding SelectedHud, Mode=TwoWay}"
                         ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                         AutomationProperties.Name="HUD attachment list">
                    <ListBox.ItemTemplate>
                        <DataTemplate x:DataType="vm:HudEntry">
                            <StackPanel Spacing="1" Margin="2,1">
                                <StackPanel.ContextMenu>
                                    <ContextMenu>
                                        <MenuItem Header="Detach"
                                                  Command="{Binding $parent[UserControl].((vm:HudViewerViewModel)DataContext).DetachHudCommand}"
                                                  CommandParameter="{Binding}"
                                                  AutomationProperties.Name="Detach HUD" />
                                    </ContextMenu>
                                </StackPanel.ContextMenu>
                                <TextBlock Text="{Binding Name}" FontWeight="SemiBold"
                                           TextTrimming="CharacterEllipsis" />
                                <TextBlock Text="{Binding AttachPoint}" FontSize="11"
                                           Opacity="0.6" TextTrimming="CharacterEllipsis" />
                            </StackPanel>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </DockPanel>
        </Border>
        <!-- Splitter -->
        <GridSplitter Grid.Column="1" Width="4" ResizeDirection="Columns"
                      Background="Transparent"
                      IsVisible="{Binding IsHudListVisible}"
                      AutomationProperties.Name="Resize panel splitter" />

        <!-- Right: Viewport area -->
        <DockPanel Grid.Column="2">

            <!-- Toolbar -->
            <Border DockPanel.Dock="Top" BorderThickness="0,0,0,1" Padding="6,3">
                <WrapPanel Orientation="Horizontal" VerticalAlignment="Center">

                    <ToggleButton IsChecked="{Binding IsHudListVisible}"
                                  Margin="0,0,8,0" Width="30" Padding="0"
                                  ToolTip.Tip="Show / hide HUD list"
                                  AutomationProperties.Name="Toggle HUD list">&#x2630;</ToggleButton>

                    <Button Content="Touch"
                            Command="{Binding TouchCommand}"
                            Margin="0,0,8,0" MinWidth="60"
                            ToolTip.Tip="Send a touch event to the selected HUD"
                            AutomationProperties.Name="Touch HUD"
                            Classes.touching="{Binding IsTouching}">
                        <Button.Styles>
                            <Style Selector="Button.touching">
                                <Setter Property="Background" Value="#3390FF" />
                                <Setter Property="Foreground" Value="White" />
                            </Style>
                        </Button.Styles>
                    </Button>

                    <Button Content="&#x27F3; Reset Camera"
                            Command="{Binding ResetCameraCommand}"
                            Margin="0,0,8,0" MinWidth="110"
                            ToolTip.Tip="Return camera to default orbit position"
                            AutomationProperties.Name="Reset camera" />

                    <!-- Orbit buttons: arrow cross (keyboard layout) -->
                    <Border BorderThickness="1,0,0,0" Padding="8,0,0,0" Margin="0,0,6,0"
                            VerticalAlignment="Center">
                        <Grid ColumnDefinitions="26,2,26,2,26" RowDefinitions="22,2,22"
                              VerticalAlignment="Center">
                            <Button Grid.Row="0" Grid.Column="2" Content="&#x2191;" Command="{Binding OrbitUpCommand}"
                                    Width="26" Height="22" Padding="0"
                                    HorizontalContentAlignment="Center"
                                    ToolTip.Tip="Orbit up" />
                            <Button Grid.Row="2" Grid.Column="0" Content="&#x2190;" Command="{Binding OrbitLeftCommand}"
                                    Width="26" Height="22" Padding="0"
                                    HorizontalContentAlignment="Center"
                                    ToolTip.Tip="Orbit left" />
                            <Button Grid.Row="2" Grid.Column="2" Content="&#x2193;" Command="{Binding OrbitDownCommand}"
                                    Width="26" Height="22" Padding="0"
                                    HorizontalContentAlignment="Center"
                                    ToolTip.Tip="Orbit down" />
                            <Button Grid.Row="2" Grid.Column="4" Content="&#x2192;" Command="{Binding OrbitRightCommand}"
                                    Width="26" Height="22" Padding="0"
                                    HorizontalContentAlignment="Center"
                                    ToolTip.Tip="Orbit right" />
                        </Grid>
                    </Border>
                    <!-- Zoom buttons -->
                    <Border BorderThickness="1,0,0,0" Padding="8,0,0,0" Margin="0,0,8,0"
                            VerticalAlignment="Center">
                        <StackPanel Orientation="Vertical" Spacing="1" VerticalAlignment="Center">
                            <Button Content="+" Command="{Binding ZoomInCommand}"
                                    Width="26" Height="22" Padding="0"
                                    HorizontalContentAlignment="Center"
                                    ToolTip.Tip="Zoom in" />
                            <Button Content="&#x2212;" Command="{Binding ZoomOutCommand}"
                                    Width="26" Height="22" Padding="0"
                                    HorizontalContentAlignment="Center"
                                    ToolTip.Tip="Zoom out" />
                        </StackPanel>
                    </Border>

                    </WrapPanel>
            </Border>
            <!-- Hover text bar -->
            <Border DockPanel.Dock="Bottom"
                    IsVisible="{Binding ShowHoverText}"
                    BorderThickness="0,1,0,0" Padding="8,4"
                    AutomationProperties.Name="Hover text display">
                <TextBlock Text="{Binding HoverText}"
                           FontStyle="Italic" TextWrapping="Wrap"
                           AutomationProperties.Name="Hover text" />
            </Border>

            <!-- Status bar -->
            <Border DockPanel.Dock="Bottom" BorderThickness="0,1,0,0" Padding="6,2">
                <Grid ColumnDefinitions="*,Auto">
                    <TextBlock Grid.Column="0"
                               Text="{Binding StatusText}"
                               VerticalAlignment="Center"
                               AutomationProperties.Name="Status" />
                    <ProgressBar Grid.Column="1"
                                 IsVisible="{Binding IsLoading}"
                                 IsIndeterminate="True"
                                 Width="80" Height="10"
                                 Margin="8,0,0,0"
                                 AutomationProperties.Name="Loading indicator" />
                </Grid>
            </Border>
            <!-- Error overlay -->
            <Border DockPanel.Dock="Top"
                    IsVisible="{Binding HasError}"
                    Background="#CC0000" Padding="8,4" Margin="0,0,0,2">
                <TextBlock Text="{Binding ErrorText}"
                           Foreground="White" TextWrapping="Wrap"
                           AutomationProperties.Name="Error message" />
            </Border>

            <!-- 3-D viewport -->
            <rendering:GlViewportControl x:Name="Viewport"
                                         HorizontalAlignment="Stretch"
                                         VerticalAlignment="Stretch"
                                         AutomationProperties.Name="HUD viewport" />

        </DockPanel>
    </Grid>
</UserControl>
