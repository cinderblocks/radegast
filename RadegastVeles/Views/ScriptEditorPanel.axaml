<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:Radegast.Veles.ViewModels"
             xmlns:views="using:Radegast.Veles.Views"
             xmlns:avaloniaEdit="clr-namespace:AvaloniaEdit;assembly=AvaloniaEdit"
             x:Class="Radegast.Veles.Views.ScriptEditorPanel"
             x:DataType="vm:ScriptEditorViewModel"
             AutomationProperties.Name="Script editor">
    <Grid RowDefinitions="Auto,*,Auto,Auto,Auto">
        <Border Grid.Row="0" BorderThickness="0,0,0,1" Padding="4,2">
            <WrapPanel Orientation="Horizontal" VerticalAlignment="Center">
                <TextBlock Text="{Binding ScriptName}" FontWeight="SemiBold" VerticalAlignment="Center" Margin="0,0,8,0" AutomationProperties.Name="Script name" />
                <Button Content="Save to SL" Command="{Binding SaveCommand}" Margin="0,0,4,0" MinWidth="76" AutomationProperties.Name="Save script to Second Life" />
                <Button x:Name="BtnSaveFile" Content="Save to File" Margin="0,0,4,0" MinWidth="80" AutomationProperties.Name="Save script to local file" />
                <Button x:Name="BtnLoadFile" Content="Load from File" Margin="0,0,8,0" MinWidth="96" AutomationProperties.Name="Load script from local file" />
                <Button x:Name="BtnDetach" Content="&#x23CF; Detach" Margin="0,0,4,0" MinWidth="72" AutomationProperties.Name="Detach script editor to its own window" />
                <Button x:Name="BtnClose" Content="&#x2715; Close" Margin="0,0,8,0" MinWidth="64" AutomationProperties.Name="Close script editor" />
                <TextBlock Text="{Binding CursorLine, StringFormat={}Ln {0}}" VerticalAlignment="Center" Margin="0,0,6,0" AutomationProperties.Name="Cursor line number" />
                <TextBlock Text="{Binding CursorColumn, StringFormat={}Col {0}}" VerticalAlignment="Center" AutomationProperties.Name="Cursor column number" />
            </WrapPanel>
        </Border>
        <avaloniaEdit:TextEditor Grid.Row="1"
                                 x:Name="ScriptEditor"
                                 ShowLineNumbers="True"
                                 FontFamily="Courier New, Consolas, Monospace"
                                 FontSize="13"
                                 WordWrap="False"
                                 AutomationProperties.Name="Script text editor"
                                 Margin="0" />
        <Border Grid.Row="2" IsVisible="{Binding HasCompileOutput}" BorderThickness="0,1,0,0" MaxHeight="120" Padding="4">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <TextBlock Text="{Binding CompileOutput}" FontFamily="Courier New, Consolas, Monospace" TextWrapping="Wrap" AutomationProperties.Name="Compile output" />
            </ScrollViewer>
        </Border>
        <ContentControl Grid.Row="3" Content="{Binding Metadata}">
            <ContentControl.ContentTemplate>
                <DataTemplate x:DataType="vm:ItemMetadataViewModel">
                    <views:ItemMetadataPanel />
                </DataTemplate>
            </ContentControl.ContentTemplate>
        </ContentControl>
        <Grid Grid.Row="4" ColumnDefinitions="*,Auto" Margin="4,2">
            <TextBlock Grid.Column="0"
                       Text="{Binding StatusText}"
                       VerticalAlignment="Center"
                       AutomationProperties.Name="Script editor status" />
            <ProgressBar Grid.Column="1"
                         IsVisible="{Binding IsLoading}"
                         IsIndeterminate="True"
                         Width="80" Height="8"
                         VerticalAlignment="Center"
                         AutomationProperties.Name="Loading indicator" />
        </Grid>
    </Grid>
</UserControl>
