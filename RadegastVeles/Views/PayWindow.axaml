<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:Radegast.Veles.ViewModels"
        x:Class="Radegast.Veles.Views.PayWindow"
        x:DataType="vm:PayViewModel"
        Title="{Binding WindowTitle}"
        Width="310" Height="270"
        CanResize="False"
        WindowStartupLocation="CenterOwner"
        Icon="/Assets/radegast.ico"
        AutomationProperties.Name="Pay window">
    <Border Padding="16">
        <StackPanel Spacing="10">
            <TextBlock Text="{Binding TargetDisplay}" FontWeight="SemiBold" TextWrapping="Wrap" AutomationProperties.Name="Payment target" />
            <TextBlock Text="{Binding BalanceText}" FontSize="12" Opacity="0.75" AutomationProperties.Name="Current L$ balance" />
            <Separator />
            <TextBlock Text="Quick pay:" FontSize="11" Opacity="0.7" />
            <StackPanel Orientation="Horizontal" Spacing="6">
                <Button Content="{Binding Quick1Text}" Command="{Binding QuickPay1Command}" IsVisible="{Binding Quick1Visible}" MinWidth="64" AutomationProperties.Name="{Binding Quick1Text}" />
                <Button Content="{Binding Quick2Text}" Command="{Binding QuickPay2Command}" IsVisible="{Binding Quick2Visible}" MinWidth="64" AutomationProperties.Name="{Binding Quick2Text}" />
                <Button Content="{Binding Quick3Text}" Command="{Binding QuickPay3Command}" IsVisible="{Binding Quick3Visible}" MinWidth="64" AutomationProperties.Name="{Binding Quick3Text}" />
                <Button Content="{Binding Quick4Text}" Command="{Binding QuickPay4Command}" IsVisible="{Binding Quick4Visible}" MinWidth="64" AutomationProperties.Name="{Binding Quick4Text}" />
            </StackPanel>
            <Separator />
            <TextBlock Text="Custom amount (L$):" FontSize="11" Opacity="0.7" />
            <TextBox x:Name="AmountBox" Text="{Binding AmountText, Mode=TwoWay}" Watermark="Enter amount" AutomationProperties.Name="Custom payment amount" />
            <TextBlock Text="{Binding StatusText}" Foreground="OrangeRed" FontSize="11" IsVisible="{Binding StatusText, Converter={x:Static StringConverters.IsNotNullOrEmpty}}" AutomationProperties.Name="Payment error" />
            <StackPanel Orientation="Horizontal" Spacing="8" HorizontalAlignment="Right" Margin="0,4,0,0">
                <Button Content="Pay" Command="{Binding PayCommand}" MinWidth="80" AutomationProperties.Name="Confirm payment" />
                <Button Content="Cancel" Command="{Binding CancelCommand}" MinWidth="80" AutomationProperties.Name="Cancel payment" />
            </StackPanel>
        </StackPanel>
    </Border>
</Window>