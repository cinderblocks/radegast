<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:Radegast.Veles.ViewModels"
             xmlns:views="using:Radegast.Veles.Views"
             x:Class="Radegast.Veles.Views.TextureViewerPanel"
             x:DataType="vm:TextureViewerViewModel"
             AutomationProperties.Name="Texture viewer">
    <DockPanel>
        <Border DockPanel.Dock="Top" BorderThickness="0,0,0,1" Padding="4,2">
            <WrapPanel Orientation="Horizontal" VerticalAlignment="Center">
                <TextBlock Text="{Binding TextureName}" FontWeight="SemiBold" VerticalAlignment="Center" Margin="0,0,8,0" AutomationProperties.Name="Texture name" />
                <Button Content="&#x1F4BE; Save" Command="{Binding SaveToFileCommand}" Margin="0,0,4,0" MinWidth="64" AutomationProperties.Name="Save texture to file" />
                <Button x:Name="BtnDetach" Content="&#x23CF; Detach" Margin="0,0,4,0" MinWidth="72" AutomationProperties.Name="Detach texture viewer" />
                <Button x:Name="BtnClose" Content="&#x2715; Close" Margin="0,0,4,0" MinWidth="64" AutomationProperties.Name="Close texture viewer" />
            </WrapPanel>
        </Border>
        <Grid DockPanel.Dock="Bottom" ColumnDefinitions="*,Auto" Margin="4,2">
            <TextBlock Grid.Column="0" Text="{Binding StatusText}" VerticalAlignment="Center" AutomationProperties.Name="Texture status" />
            <ProgressBar Grid.Column="1" IsVisible="{Binding IsLoading}" Value="{Binding DownloadProgress}" Minimum="0" Maximum="100" Width="80" Height="8" VerticalAlignment="Center" Margin="4,0" AutomationProperties.Name="Download progress" />
        </Grid>
        <ContentControl DockPanel.Dock="Bottom" Content="{Binding Metadata}">
            <ContentControl.ContentTemplate>
                <DataTemplate x:DataType="vm:ItemMetadataViewModel">
                    <views:ItemMetadataPanel />
                </DataTemplate>
            </ContentControl.ContentTemplate>
        </ContentControl>
        <Panel>
            <Image Source="{Binding TextureBitmap}" Stretch="Uniform" AutomationProperties.Name="Texture image" />
            <TextBlock IsVisible="{Binding IsLoading}" Text="Loading texture..."
                       HorizontalAlignment="Center" VerticalAlignment="Center"
                       AutomationProperties.Name="Loading text" />
        </Panel>
    </DockPanel>
</UserControl>
