<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:Radegast.Veles.ViewModels"
             xmlns:views="using:Radegast.Veles.Views"
             x:Class="Radegast.Veles.Views.LandmarkPanel"
             x:DataType="vm:LandmarkViewModel"
             AutomationProperties.Name="Landmark viewer">
    <DockPanel>
        <Border DockPanel.Dock="Top" BorderThickness="0,0,0,1" Padding="4,2">
            <WrapPanel Orientation="Horizontal" VerticalAlignment="Center">
                <TextBlock Text="{Binding LandmarkName}" FontWeight="SemiBold" VerticalAlignment="Center" Margin="0,0,8,0" AutomationProperties.Name="Landmark name" />
                <Button Content="&#x2708; Teleport" Command="{Binding TeleportCommand}" Margin="0,0,4,0" MinWidth="80" AutomationProperties.Name="Teleport to landmark" />
                <Button x:Name="BtnDetach" Content="&#x23CF; Detach" Margin="0,0,4,0" MinWidth="72" AutomationProperties.Name="Detach landmark viewer" />
                <Button x:Name="BtnClose" Content="&#x2715; Close" Margin="0,0,4,0" MinWidth="64" AutomationProperties.Name="Close landmark viewer" />
            </WrapPanel>
        </Border>
        <Grid DockPanel.Dock="Bottom" ColumnDefinitions="*,Auto" Margin="4,2">
            <TextBlock Grid.Column="0" Text="{Binding StatusText}" VerticalAlignment="Center" AutomationProperties.Name="Landmark status" />
            <ProgressBar Grid.Column="1" IsVisible="{Binding IsLoading}" IsIndeterminate="True" Width="80" Height="8" VerticalAlignment="Center" AutomationProperties.Name="Loading indicator" />
        </Grid>
        <ContentControl DockPanel.Dock="Bottom" Content="{Binding Metadata}">
            <ContentControl.ContentTemplate>
                <DataTemplate x:DataType="vm:ItemMetadataViewModel">
                    <views:ItemMetadataPanel />
                </DataTemplate>
            </ContentControl.ContentTemplate>
        </ContentControl>
        <ScrollViewer>
            <StackPanel Margin="8" Spacing="6">

                <!-- Parcel snapshot -->
                <Border CornerRadius="6" ClipToBounds="True" Height="160"
                        IsVisible="{Binding ParcelSnapshot, Converter={x:Static ObjectConverters.IsNotNull}}"
                        AutomationProperties.Name="Parcel snapshot">
                    <Image Source="{Binding ParcelSnapshot}" Stretch="UniformToFill" />
                </Border>

                <Grid ColumnDefinitions="Auto,*" RowDefinitions="Auto,Auto,Auto,Auto" IsVisible="{Binding CanTeleport}">
                    <TextBlock Grid.Row="0" Grid.Column="0" Text="Region:" FontWeight="SemiBold" Margin="0,0,8,2" VerticalAlignment="Top" />
                    <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding SimName}" TextWrapping="Wrap" AutomationProperties.Name="Region name" />
                    <TextBlock Grid.Row="1" Grid.Column="0" Text="Parcel:" FontWeight="SemiBold" Margin="0,0,8,2" VerticalAlignment="Top" />
                    <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding ParcelName}" TextWrapping="Wrap" AutomationProperties.Name="Parcel name" />
                    <TextBlock Grid.Row="2" Grid.Column="0" Text="Location:" FontWeight="SemiBold" Margin="0,0,8,2" />
                    <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding CoordinatesText}" AutomationProperties.Name="Coordinates" />
                    <TextBlock Grid.Row="3" Grid.Column="0" Text="Description:" FontWeight="SemiBold" Margin="0,0,8,2" VerticalAlignment="Top" />
                    <TextBlock Grid.Row="3" Grid.Column="1" Text="{Binding ParcelDescription}" TextWrapping="Wrap" AutomationProperties.Name="Parcel description" />
                </Grid>
                <TextBlock IsVisible="{Binding IsLoading}" Text="Resolving landmark location..." AutomationProperties.Name="Loading text" />
            </StackPanel>
        </ScrollViewer>
    </DockPanel>
</UserControl>
