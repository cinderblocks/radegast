<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:Radegast.Veles.ViewModels"
             xmlns:views="using:Radegast.Veles.Views"
             x:Class="Radegast.Veles.Views.CallingCardPanel"
             x:DataType="vm:CallingCardViewModel"
             AutomationProperties.Name="Calling card viewer">
    <DockPanel>
        <Border DockPanel.Dock="Top" BorderThickness="0,0,0,1" Padding="4,2">
            <WrapPanel Orientation="Horizontal" VerticalAlignment="Center">
                <TextBlock Text="{Binding CardName}" FontWeight="SemiBold" VerticalAlignment="Center" Margin="0,0,8,0" AutomationProperties.Name="Card name" />
                <Button Content="&#x1F464; Profile" Command="{Binding ViewProfileCommand}" Margin="0,0,4,0" MinWidth="72" AutomationProperties.Name="View full profile" />
                <Button Content="&#x2709; IM" Command="{Binding SendIMCommand}" Margin="0,0,8,0" MinWidth="48" AutomationProperties.Name="Send instant message" />
                <Button x:Name="BtnDetach" Content="&#x23CF; Detach" Margin="0,0,4,0" MinWidth="72" AutomationProperties.Name="Detach calling card viewer" />
                <Button x:Name="BtnClose" Content="&#x2715; Close" Margin="0,0,4,0" MinWidth="64" AutomationProperties.Name="Close calling card viewer" />
            </WrapPanel>
        </Border>
        <Grid DockPanel.Dock="Bottom" ColumnDefinitions="*,Auto" Margin="4,2">
            <TextBlock Grid.Column="0" Text="{Binding StatusText}" VerticalAlignment="Center" AutomationProperties.Name="Status" />
            <ProgressBar Grid.Column="1" IsVisible="{Binding IsLoading}" IsIndeterminate="True" Width="80" Height="8" VerticalAlignment="Center" AutomationProperties.Name="Loading indicator" />
        </Grid>
        <ContentControl DockPanel.Dock="Bottom" Content="{Binding Metadata}">
            <ContentControl.ContentTemplate>
                <DataTemplate x:DataType="vm:ItemMetadataViewModel">
                    <views:ItemMetadataPanel />
                </DataTemplate>
            </ContentControl.ContentTemplate>
        </ContentControl>
        <ScrollViewer HorizontalScrollBarVisibility="Disabled">
            <StackPanel Margin="8" Spacing="8">

                <!-- Profile card with avatar image -->
                <Border Background="#18FFFFFF" CornerRadius="6" Padding="12">
                    <Grid ColumnDefinitions="Auto,12,*">
                        <Border Grid.Column="0" Width="100" Height="100" CornerRadius="6"
                                ClipToBounds="True" Background="#10FFFFFF"
                                AutomationProperties.Name="Profile image">
                            <Image Source="{Binding ProfileImage}" Stretch="UniformToFill" />
                        </Border>
                        <StackPanel Grid.Column="2" Spacing="4" VerticalAlignment="Center">
                            <TextBlock Text="{Binding AvatarName}" FontSize="16" FontWeight="Bold"
                                       TextWrapping="Wrap"
                                       AutomationProperties.Name="Avatar name" />
                            <TextBlock Text="{Binding BornOn, StringFormat=Born: {0}}" Opacity="0.7"
                                       IsVisible="{Binding BornOn, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"
                                       AutomationProperties.Name="Born date" />
                            <TextBlock Text="{Binding AccountInfo}" Opacity="0.7"
                                       IsVisible="{Binding AccountInfo, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"
                                       AutomationProperties.Name="Account info" />
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- About text -->
                <Border Background="#18FFFFFF" CornerRadius="6" Padding="12"
                        IsVisible="{Binding AboutText, Converter={x:Static StringConverters.IsNotNullOrEmpty}}">
                    <StackPanel Spacing="4">
                        <TextBlock Text="About" FontWeight="SemiBold" FontSize="13" Opacity="0.7" />
                        <TextBlock Text="{Binding AboutText}" TextWrapping="Wrap"
                                   AutomationProperties.Name="About text" />
                    </StackPanel>
                </Border>

            </StackPanel>
        </ScrollViewer>
    </DockPanel>
</UserControl>
