<!-- Radegast Metaverse Client Copyright (c) 2026, Sjofn LLC --><UserControl xmlns="https://github.com/avaloniaui" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml" xmlns:vm="using:Radegast.Veles.ViewModels" xmlns:controls="using:Radegast.Veles.Controls" x:Class="Radegast.Veles.Views.ScriptDialogOverlay" x:DataType="vm:NotificationQueueViewModel" AutomationProperties.Name="Notifications overlay"><Border Background="#1C2D3E" BorderBrush="#2472A4" BorderThickness="1" CornerRadius="6" MaxWidth="340" MinWidth="260" BoxShadow="0 4 16 2 #80000000" IsVisible="{Binding IsVisible}"><StackPanel><Border Background="#154360" CornerRadius="5,5,0,0" Padding="8,6"><DockPanel><StackPanel DockPanel.Dock="Right" Orientation="Horizontal" Spacing="2" VerticalAlignment="Center" IsVisible="{Binding HasMultiple}" AutomationProperties.Name="Notification navigation"><Button Content="&#x25C4;" Command="{Binding PreviousCommand}" Padding="4,2" MinWidth="0" MinHeight="0" AutomationProperties.Name="Previous notification" /><TextBlock Text="{Binding PositionText}" VerticalAlignment="Center" FontSize="11" Margin="4,0" Foreground="White" /><Button Content="&#x25BA;" Command="{Binding NextCommand}" Padding="4,2" MinWidth="0" MinHeight="0" AutomationProperties.Name="Next notification" /></StackPanel><StackPanel Spacing="1" VerticalAlignment="Center"><TextBlock Text="{Binding Current.Title}" FontWeight="SemiBold" Foreground="White" TextTrimming="CharacterEllipsis" AutomationProperties.Name="Notification title" /><TextBlock Text="{Binding Current.Subtitle}" FontSize="11" Foreground="#B0C4DE" TextTrimming="CharacterEllipsis" AutomationProperties.Name="Notification subtitle" /></StackPanel></DockPanel></Border><ScrollViewer MaxHeight="160"><controls:RichChatText Text="{Binding Current.Message}" Margin="8,8,8,4" /></ScrollViewer><StackPanel Margin="8,4,8,4" Spacing="4" IsVisible="{Binding Current.IsTextBox}"><TextBox Text="{Binding Current.TextInput, Mode=TwoWay}" PlaceholderText="Enter text..." x:Name="TextInputBox" AutomationProperties.Name="Notification text input" /><Button Content="Send" Command="{Binding Current.SendTextCommand}" HorizontalAlignment="Right" Padding="12,4" /></StackPanel><ItemsControl ItemsSource="{Binding Current.Buttons}" Margin="8,4,8,4" IsVisible="{Binding Current.IsButtonMode}"><ItemsControl.ItemsPanel><ItemsPanelTemplate><WrapPanel /></ItemsPanelTemplate></ItemsControl.ItemsPanel><ItemsControl.ItemTemplate><DataTemplate x:DataType="vm:NotificationButtonViewModel"><Button Content="{Binding Label}" Command="{Binding Command}" MinWidth="80" Margin="2" AutomationProperties.Name="{Binding Label}" /></DataTemplate></ItemsControl.ItemTemplate></ItemsControl><Border Padding="8,4,8,6" BorderThickness="0,1,0,0" BorderBrush="#1A3A5C"><Button Content="Ignore" Command="{Binding Current.IgnoreCommand}" HorizontalAlignment="Right" Padding="12,4" AutomationProperties.Name="Ignore notification" /></Border></StackPanel></Border></UserControl>
