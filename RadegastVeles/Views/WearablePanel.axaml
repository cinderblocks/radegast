<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:Radegast.Veles.ViewModels"
             xmlns:views="using:Radegast.Veles.Views"
             x:Class="Radegast.Veles.Views.WearablePanel"
             x:DataType="vm:WearableViewModel"
             AutomationProperties.Name="Wearable viewer">
    <DockPanel>

        <!-- Toolbar -->
        <Border DockPanel.Dock="Top" BorderThickness="0,0,0,1" Padding="4,2">
            <WrapPanel Orientation="Horizontal" VerticalAlignment="Center">
                <TextBlock Text="{Binding WearableName}" FontWeight="SemiBold" VerticalAlignment="Center"
                           Margin="0,0,8,0" AutomationProperties.Name="Wearable name" />
                <Button Content="&#x1F457; Wear" Command="{Binding WearCommand}"
                        IsVisible="{Binding !IsWorn}"
                        Margin="0,0,4,0" MinWidth="72"
                        AutomationProperties.Name="Wear this item" />
                <Button Content="&#x274C; Take Off" Command="{Binding TakeOffCommand}"
                        IsVisible="{Binding IsWorn}"
                        Margin="0,0,8,0" MinWidth="88"
                        AutomationProperties.Name="Take off this item" />
                <Button x:Name="BtnDetach" Content="&#x23CF; Detach" Margin="0,0,4,0" MinWidth="72"
                        AutomationProperties.Name="Detach wearable viewer" />
                <Button x:Name="BtnClose" Content="&#x2715; Close" Margin="0,0,4,0" MinWidth="64"
                        AutomationProperties.Name="Close wearable viewer" />
            </WrapPanel>
        </Border>

        <!-- Status bar -->
        <TextBlock DockPanel.Dock="Bottom" Text="{Binding StatusText}" Margin="4,2"
                   VerticalAlignment="Center" AutomationProperties.Name="Wearable status" />

        <ContentControl DockPanel.Dock="Bottom" Content="{Binding Metadata}">
            <ContentControl.ContentTemplate>
                <DataTemplate x:DataType="vm:ItemMetadataViewModel">
                    <views:ItemMetadataPanel />
                </DataTemplate>
            </ContentControl.ContentTemplate>
        </ContentControl>

        <!-- Center content -->
        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Spacing="12" Margin="24">
            <TextBlock Text="{Binding WearableTypeIcon}" FontSize="48" HorizontalAlignment="Center"
                       AutomationProperties.Name="Wearable icon" />
            <TextBlock Text="{Binding WearableName}" FontSize="14" FontWeight="SemiBold"
                       HorizontalAlignment="Center" TextWrapping="Wrap"
                       AutomationProperties.Name="Wearable name label" />

            <Grid ColumnDefinitions="Auto,8,*" RowDefinitions="Auto,Auto" HorizontalAlignment="Center">
                <TextBlock Grid.Row="0" Grid.Column="0" Text="Type:" FontWeight="SemiBold"
                           VerticalAlignment="Center" />
                <TextBlock Grid.Row="0" Grid.Column="2" Text="{Binding WearableTypeText}"
                           VerticalAlignment="Center" AutomationProperties.Name="Wearable type" />
                <TextBlock Grid.Row="1" Grid.Column="0" Text="Category:" FontWeight="SemiBold"
                           VerticalAlignment="Center" Margin="0,4,0,0" />
                <TextBlock Grid.Row="1" Grid.Column="2" Text="{Binding WearableCategoryText}"
                           VerticalAlignment="Center" Margin="0,4,0,0"
                           AutomationProperties.Name="Wearable category" />
            </Grid>

            <!-- Worn indicator -->
            <Border Background="{DynamicResource VelesBadgeAttached}" CornerRadius="4" Padding="8,4"
                    IsVisible="{Binding IsWorn}" HorizontalAlignment="Center">
                <TextBlock Text="&#x1F4CC; Currently Worn" Foreground="White" FontWeight="SemiBold"
                           AutomationProperties.Name="Currently worn badge" />
            </Border>

            <!-- Textures section -->
            <StackPanel IsVisible="{Binding HasTextures}" Spacing="4" Margin="0,8,0,0"
                        AutomationProperties.Name="Wearable textures">
                <TextBlock Text="Textures" FontWeight="SemiBold" />
                <ItemsControl ItemsSource="{Binding Textures}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate x:DataType="vm:WearableTextureSlot">
                            <Grid ColumnDefinitions="*,4,Auto" Margin="0,2">
                                <TextBlock Grid.Column="0" Text="{Binding SlotName}" VerticalAlignment="Center"
                                           AutomationProperties.Name="{Binding SlotName}" />
                                <Button Grid.Column="2" Content="View"
                                        Command="{Binding $parent[UserControl].((vm:WearableViewModel)DataContext).ViewTextureCommand}"
                                        CommandParameter="{Binding}"
                                        MinWidth="48"
                                        AutomationProperties.Name="View texture" />
                            </Grid>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </StackPanel>
            <TextBlock Text="Loading textures..." IsVisible="{Binding IsLoadingTextures}"
                       Foreground="{DynamicResource VelesMutedForeground}" AutomationProperties.Name="Loading textures indicator" />
        </StackPanel>

    </DockPanel>
</UserControl>
