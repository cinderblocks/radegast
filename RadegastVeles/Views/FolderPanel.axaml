<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:Radegast.Veles.ViewModels"
             x:Class="Radegast.Veles.Views.FolderPanel"
             x:DataType="vm:FolderViewModel"
             AutomationProperties.Name="Folder details panel">
    <ScrollViewer HorizontalScrollBarVisibility="Disabled" VerticalScrollBarVisibility="Auto">
        <StackPanel Spacing="0" Margin="12,10">

            <!-- Header: icon + name -->
            <StackPanel Orientation="Horizontal" Spacing="12" Margin="0,0,0,12">
                <TextBlock Text="&#x1F4C1;" FontSize="48" VerticalAlignment="Center"
                           AutomationProperties.Name="Folder icon" />
                <StackPanel VerticalAlignment="Center" Spacing="4">
                    <TextBlock Text="{Binding FolderName}" FontSize="16" FontWeight="SemiBold"
                               TextWrapping="Wrap" AutomationProperties.Name="Folder name" />
                    <TextBlock Text="{Binding FolderPath}" FontSize="11" Opacity="0.6"
                               TextWrapping="Wrap" AutomationProperties.Name="Folder path" />
                </StackPanel>
            </StackPanel>

            <!-- Stats grid -->
            <Border Background="#11808080" CornerRadius="4" Padding="10,8" Margin="0,0,0,10">
                <Grid ColumnDefinitions="Auto,*" RowDefinitions="Auto,Auto,Auto" HorizontalAlignment="Stretch">

                    <TextBlock Grid.Row="0" Grid.Column="0" Text="Subfolders:" FontWeight="SemiBold"
                               Margin="0,0,16,4" VerticalAlignment="Center" />
                    <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding DirectFolderCount}"
                               VerticalAlignment="Center" AutomationProperties.Name="Subfolder count" />

                    <TextBlock Grid.Row="1" Grid.Column="0" Text="Items:" FontWeight="SemiBold"
                               Margin="0,0,16,4" VerticalAlignment="Center" />
                    <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding DirectItemCount}"
                               VerticalAlignment="Center" AutomationProperties.Name="Item count" />

                    <TextBlock Grid.Row="2" Grid.Column="0" Text="Total Contents:" FontWeight="SemiBold"
                               Margin="0,0,16,0" VerticalAlignment="Center" />
                    <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding TotalDescendantCount}"
                               VerticalAlignment="Center" AutomationProperties.Name="Total descendant count" />

                </Grid>
            </Border>

        </StackPanel>
    </ScrollViewer>
</UserControl>
