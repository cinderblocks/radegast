<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:Radegast.Veles.ViewModels"
        xmlns:controls="using:Radegast.Veles.Controls"
        x:Class="Radegast.Veles.Views.ChatWindow"
        x:DataType="vm:NearbyViewModel"
        Title="Radegast Veles"
        Width="900" Height="620"
        MinWidth="700" MinHeight="450"
        WindowStartupLocation="CenterScreen"
        Icon="/Assets/veles.ico"
        AutomationProperties.Name="Radegast Veles main chat window">

    <DockPanel>
        <!-- Status bar -->
        <Border DockPanel.Dock="Bottom" Background="{DynamicResource SystemControlBackgroundChromeMediumBrush}" Padding="8,4" AutomationProperties.Name="Status bar">
            <Grid ColumnDefinitions="*,Auto">
                <TextBlock Grid.Column="0" Text="{Binding LocationText}" VerticalAlignment="Center" AutomationProperties.Name="Current location" />
                <TextBlock Grid.Column="1" Text="{Binding StatusText}" VerticalAlignment="Center" AutomationProperties.Name="Connection status" />
            </Grid>
        </Border>

        <!-- Main content -->
        <Grid ColumnDefinitions="*,8,260">
            <!-- Left: Chat area -->
            <DockPanel Grid.Column="0">
                <!-- Chat input -->
                <Grid DockPanel.Dock="Bottom" ColumnDefinitions="Auto,*,Auto" Margin="4" AutomationProperties.Name="Chat input area">
                    <ComboBox Grid.Column="0" ItemsSource="{Binding ChatTypes}" SelectedIndex="{Binding SelectedChatTypeIndex}" MinWidth="90" VerticalAlignment="Stretch" AutomationProperties.Name="Chat type selector" />
                    <TextBox Grid.Column="1" x:Name="ChatInputBox" Text="{Binding ChatInput, Mode=TwoWay}" PlaceholderText="Type a message..." Margin="4,0" VerticalAlignment="Center" AutomationProperties.Name="Chat message input" AutomationProperties.HelpText="Type your message and press Enter to send" />
                    <Button Grid.Column="2" Content="Send" Command="{Binding SendChatCommand}" MinWidth="60" VerticalAlignment="Stretch" AutomationProperties.Name="Send chat message" />
                </Grid>

                <!-- Chat log -->
                <ListBox x:Name="ChatLog" ItemsSource="{Binding ChatLines}" Margin="4,4,4,0" AutomationProperties.Name="Chat message history" ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                    <ListBox.ItemTemplate>
                        <DataTemplate x:DataType="vm:ChatLine">
                            <TextBlock Text="{Binding AutomationText}" TextWrapping="Wrap" AutomationProperties.Name="{Binding AutomationText}" />
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </DockPanel>

            <!-- Splitter -->
            <GridSplitter Grid.Column="1" ResizeDirection="Columns" Background="Transparent" AutomationProperties.Name="Resize panel splitter" />

            <!-- Right panel -->
            <DockPanel Grid.Column="2">
                <!-- Movement controls -->
                <Border DockPanel.Dock="Top" Padding="4" AutomationProperties.Name="Movement controls">
                    <StackPanel Spacing="4">
                        <TextBlock Text="Movement" FontWeight="SemiBold" Margin="0,0,0,4" />
                        <Grid ColumnDefinitions="*,*,*" RowDefinitions="Auto,Auto,Auto" HorizontalAlignment="Center">
                            <Button x:Name="BtnForward" Grid.Row="0" Grid.Column="1" Content="&#x25B2;" HorizontalAlignment="Stretch" HorizontalContentAlignment="Center" MinWidth="44" MinHeight="36" AutomationProperties.Name="Move forward" />
                            <Button x:Name="BtnLeft" Grid.Row="1" Grid.Column="0" Content="&#x25C0;" HorizontalAlignment="Stretch" HorizontalContentAlignment="Center" MinWidth="44" MinHeight="36" AutomationProperties.Name="Turn left" />
                            <Button x:Name="BtnRight" Grid.Row="1" Grid.Column="2" Content="&#x25B6;" HorizontalAlignment="Stretch" HorizontalContentAlignment="Center" MinWidth="44" MinHeight="36" AutomationProperties.Name="Turn right" />
                            <Button x:Name="BtnBackward" Grid.Row="2" Grid.Column="1" Content="&#x25BC;" HorizontalAlignment="Stretch" HorizontalContentAlignment="Center" MinWidth="44" MinHeight="36" AutomationProperties.Name="Move backward" />
                        </Grid>
                        <WrapPanel HorizontalAlignment="Center" Orientation="Horizontal">
                            <Button x:Name="BtnJump" Content="Jump" Margin="2" MinWidth="52" AutomationProperties.Name="Jump" />
                            <Button x:Name="BtnCrouch" Content="Crouch" Margin="2" MinWidth="52" AutomationProperties.Name="Crouch" />
                            <ToggleButton Content="Fly" IsChecked="{Binding IsFlying}" Command="{Binding ToggleFlyCommand}" Margin="2" MinWidth="52" AutomationProperties.Name="Toggle flying" />
                            <ToggleButton Content="Run" IsChecked="{Binding IsRunning}" Command="{Binding ToggleRunCommand}" Margin="2" MinWidth="52" AutomationProperties.Name="Toggle running" />
                        </WrapPanel>
                    </StackPanel>
                </Border>

                <!-- Minimap -->
                <Border DockPanel.Dock="Bottom" Padding="4" AutomationProperties.Name="Minimap area">
                    <StackPanel Spacing="4">
                        <TextBlock Text="Minimap" FontWeight="SemiBold" />
                        <controls:MinimapControl Entries="{Binding MinimapEntries}" Height="180" />
                    </StackPanel>
                </Border>

                <!-- Nearby avatars -->
                <Border Padding="4" AutomationProperties.Name="Nearby avatars area">
                    <DockPanel>
                        <TextBlock DockPanel.Dock="Top" Text="Nearby" FontWeight="SemiBold" Margin="0,0,0,4" />
                        <ListBox ItemsSource="{Binding NearbyAvatars}" AutomationProperties.Name="Nearby avatars list" ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                            <ListBox.ItemTemplate>
                                <DataTemplate x:DataType="vm:NearbyAvatar">
                                    <TextBlock Text="{Binding DisplayText}" TextWrapping="NoWrap" TextTrimming="CharacterEllipsis" AutomationProperties.Name="{Binding DisplayText}" />
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                    </DockPanel>
                </Border>
            </DockPanel>
        </Grid>
    </DockPanel>
</Window>
