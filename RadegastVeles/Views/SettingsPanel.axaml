<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:Radegast.Veles.ViewModels"
             xmlns:views="using:Radegast.Veles.Views"
             x:Class="Radegast.Veles.Views.SettingsPanel"
             x:DataType="vm:SettingsViewModel"
             AutomationProperties.Name="Environment settings viewer">
    <DockPanel>
        <ContentControl DockPanel.Dock="Bottom" Content="{Binding Metadata}">
            <ContentControl.ContentTemplate>
                <DataTemplate x:DataType="vm:ItemMetadataViewModel">
                    <views:ItemMetadataPanel />
                </DataTemplate>
            </ContentControl.ContentTemplate>
        </ContentControl>

        <ScrollViewer HorizontalScrollBarVisibility="Disabled" VerticalScrollBarVisibility="Auto">
            <StackPanel Spacing="0" Margin="12,10">

                <!-- Header: icon + name + type badge -->
                <StackPanel Orientation="Horizontal" Spacing="12" Margin="0,0,0,10">
                    <TextBlock Text="&#x1F324;&#xFE0F;" FontSize="40" VerticalAlignment="Center"
                               AutomationProperties.Name="Settings icon" />
                    <StackPanel VerticalAlignment="Center" Spacing="4">
                        <TextBlock Text="{Binding SettingsName}" FontSize="14" FontWeight="SemiBold"
                                   TextWrapping="Wrap" AutomationProperties.Name="Settings name" />
                        <Border Background="#0288D1" CornerRadius="3" Padding="5,2" HorizontalAlignment="Left">
                            <TextBlock Text="Environment Settings" FontSize="11" Foreground="White" />
                        </Border>
                    </StackPanel>
                </StackPanel>

                <TextBlock Text="Extended Environment (EEP) settings asset. Controls sky, water, and day cycle appearance."
                           TextWrapping="Wrap" Opacity="0.7" FontSize="11" Margin="0,4,0,0" />

            </StackPanel>
        </ScrollViewer>
    </DockPanel>
</UserControl>
