<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:Radegast.Veles.ViewModels"
             xmlns:views="using:Radegast.Veles.Views"
             x:Class="Radegast.Veles.Views.NotecardPanel"
             x:DataType="vm:NotecardViewModel"
             AutomationProperties.Name="Notecard editor">
    <DockPanel>
        <Border DockPanel.Dock="Top" BorderThickness="0,0,0,1" Padding="4,2">
            <WrapPanel Orientation="Horizontal" VerticalAlignment="Center">
                <TextBlock Text="{Binding NotecardName}" FontWeight="SemiBold" VerticalAlignment="Center" Margin="0,0,8,0" AutomationProperties.Name="Notecard name" />
                <Button Content="Save" Command="{Binding SaveCommand}" Margin="0,0,4,0" MinWidth="60" AutomationProperties.Name="Save notecard" />
                <Button Content="Refresh" Command="{Binding RefreshCommand}" Margin="0,0,8,0" MinWidth="60" AutomationProperties.Name="Refresh notecard" />
                <Button x:Name="BtnDetach" Content="&#x23CF; Detach" Margin="0,0,4,0" MinWidth="72" AutomationProperties.Name="Detach notecard editor to its own window" />
                <Button x:Name="BtnClose" Content="&#x2715; Close" Margin="0,0,4,0" MinWidth="64" AutomationProperties.Name="Close notecard editor" />
            </WrapPanel>
        </Border>
        <Grid DockPanel.Dock="Bottom" ColumnDefinitions="*,Auto" Margin="4,2">
            <TextBlock Grid.Column="0" Text="{Binding StatusText}" VerticalAlignment="Center" AutomationProperties.Name="Notecard editor status" />
            <ProgressBar Grid.Column="1" IsVisible="{Binding IsLoading}" IsIndeterminate="True" Width="80" Height="8" VerticalAlignment="Center" AutomationProperties.Name="Loading indicator" />
        </Grid>
        <ContentControl DockPanel.Dock="Bottom" Content="{Binding Metadata}">
            <ContentControl.ContentTemplate>
                <DataTemplate x:DataType="vm:ItemMetadataViewModel">
                    <views:ItemMetadataPanel />
                </DataTemplate>
            </ContentControl.ContentTemplate>
        </ContentControl>
        <TextBox AcceptsReturn="True"
                 AcceptsTab="True"
                 Text="{Binding Content, Mode=TwoWay}"
                 TextWrapping="Wrap"
                 IsReadOnly="{Binding IsLoading}"
                 AutomationProperties.Name="Notecard text editor"
                 Margin="0" />
    </DockPanel>
</UserControl>
