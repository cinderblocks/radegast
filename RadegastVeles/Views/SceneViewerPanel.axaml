<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:Radegast.Veles.ViewModels"
             xmlns:rendering="using:Radegast.Veles.Rendering"
             xmlns:conv="using:Radegast.Veles.Converters"
             x:Class="Radegast.Veles.Views.SceneViewerPanel"
             x:DataType="vm:SceneViewerViewModel"
             AutomationProperties.Name="3D scene viewer">

    <DockPanel>

        <Border DockPanel.Dock="Top" BorderThickness="0,0,0,1" Padding="6,3">
            <WrapPanel Orientation="Horizontal" VerticalAlignment="Center">
                <TextBlock Text="Scene Viewer"
                           FontWeight="SemiBold" VerticalAlignment="Center"
                           Margin="0,0,12,0" />

                <Button Content="Reset Camera"
                        Command="{Binding ResetCameraCommand}"
                        Margin="0,0,8,0" MinWidth="110"
                        ToolTip.Tip="Return camera to default orbit position"
                        AutomationProperties.Name="Reset camera" />

                <Border BorderThickness="1,0,0,0" Padding="8,0,0,0" Margin="0,0,6,0"
                        VerticalAlignment="Center">
                    <Grid ColumnDefinitions="26,2,26,2,26" RowDefinitions="22,2,22"
                          VerticalAlignment="Center">
                        <Button Grid.Row="0" Grid.Column="2" Content="^" Command="{Binding OrbitUpCommand}"
                                Width="26" Height="22" Padding="0"
                                HorizontalContentAlignment="Center"
                                ToolTip.Tip="Orbit up (10 deg)"
                                AutomationProperties.Name="Orbit camera up" />
                        <Button Grid.Row="2" Grid.Column="0" Content="&lt;" Command="{Binding OrbitLeftCommand}"
                                Width="26" Height="22" Padding="0"
                                HorizontalContentAlignment="Center"
                                ToolTip.Tip="Orbit left (15 deg)"
                                AutomationProperties.Name="Orbit camera left" />
                        <Button Grid.Row="2" Grid.Column="2" Content="v" Command="{Binding OrbitDownCommand}"
                                Width="26" Height="22" Padding="0"
                                HorizontalContentAlignment="Center"
                                ToolTip.Tip="Orbit down (10 deg)"
                                AutomationProperties.Name="Orbit camera down" />
                        <Button Grid.Row="2" Grid.Column="4" Content="&gt;" Command="{Binding OrbitRightCommand}"
                                Width="26" Height="22" Padding="0"
                                HorizontalContentAlignment="Center"
                                ToolTip.Tip="Orbit right (15 deg)"
                                AutomationProperties.Name="Orbit camera right" />
                    </Grid>
                </Border>

                <Border BorderThickness="1,0,0,0" Padding="8,0,0,0" Margin="0,0,8,0"
                        VerticalAlignment="Center">
                    <StackPanel Orientation="Vertical" Spacing="1" VerticalAlignment="Center">
                        <Button Content="+" Command="{Binding ZoomInCommand}"
                                Width="26" Height="22" Padding="0"
                                HorizontalContentAlignment="Center"
                                ToolTip.Tip="Zoom in"
                                AutomationProperties.Name="Zoom in" />
                        <Button Content="-" Command="{Binding ZoomOutCommand}"
                                Width="26" Height="22" Padding="0"
                                HorizontalContentAlignment="Center"
                                ToolTip.Tip="Zoom out"
                                AutomationProperties.Name="Zoom out" />
                    </StackPanel>
                </Border>

                <CheckBox Content="Wireframe"
                          IsChecked="{Binding Wireframe}"
                          VerticalAlignment="Center"
                          Margin="0,0,6,0"
                          AutomationProperties.Name="Toggle wireframe overlay" />

                <CheckBox Content="Chat"
                          IsChecked="{Binding ShowChatOverlay}"
                          VerticalAlignment="Center"
                          Margin="0,0,6,0"
                          ToolTip.Tip="Show nearby chat messages over the scene"
                          AutomationProperties.Name="Toggle nearby chat overlay" />

                <CheckBox Content="Perf Overlay"
                          IsChecked="{Binding ShowPerfOverlay}"
                          VerticalAlignment="Center"
                          Margin="0,0,6,0"
                          ToolTip.Tip="Show per-frame CPU/GPU timing, draw call, and cull statistics"
                          AutomationProperties.Name="Toggle performance overlay" />



                </WrapPanel>
        </Border>

        <Border DockPanel.Dock="Bottom" BorderThickness="0,1,0,0" Padding="6,2">
            <StackPanel Orientation="Vertical" Spacing="0">
                <TextBlock Text="{Binding StatusText}"
                           VerticalAlignment="Center"
                           AutomationProperties.Name="Scene viewer status" />
                <TextBlock Text="{Binding SelectedInfo}"
                           VerticalAlignment="Center"
                           FontSize="11"
                           IsVisible="{Binding SelectedInfo, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"
                           AutomationProperties.Name="Selected object info" />
            </StackPanel>
        </Border>

        <Grid HorizontalAlignment="Stretch" VerticalAlignment="Stretch">
            <rendering:GlViewportControl x:Name="Viewport"
                                         Wireframe="{Binding Wireframe}"
                                         HorizontalAlignment="Stretch"
                                         VerticalAlignment="Stretch"
                                         ToolTip.Tip="Alt+drag: orbit  |  Alt+Ctrl+drag: pan  |  Alt+Ctrl+Shift+drag: dolly  |  Scroll: zoom  |  Click: select/interact"
                                         AutomationProperties.Name="3D scene viewport">
                <rendering:GlViewportControl.ContextMenu>
                    <ContextMenu>
                        <MenuItem Header="{Binding ContextLabel}" IsEnabled="False" FontWeight="SemiBold" />
                        <Separator />
                        <MenuItem Header="Touch" Command="{Binding TouchObjectCommand}" IsVisible="{Binding ContextIsPrim}" />
                        <MenuItem Header="Sit Here" Command="{Binding SitOnCommand}" IsVisible="{Binding ContextIsPrim}" />
                        <MenuItem Header="Inspect" Command="{Binding InspectObjectCommand}" IsVisible="{Binding ContextIsPrim}" />
                        <MenuItem Header="Teleport To" Command="{Binding TeleportToAvatarCommand}" IsVisible="{Binding ContextIsAvatar}" />
                        <MenuItem Header="Focus Camera" Command="{Binding CameraFocusCommand}" />
                        <Separator />
                        <MenuItem Header="Stand Up" Command="{Binding StandUpCommand}" IsVisible="{Binding ContextIsSitting}" />
                    </ContextMenu>
                </rendering:GlViewportControl.ContextMenu>
            </rendering:GlViewportControl>

            <!-- Performance stats overlay (top-left, shown when ShowPerfOverlay is true) -->
            <Border IsHitTestVisible="False"
                    IsVisible="{Binding ShowPerfOverlay}"
                    HorizontalAlignment="Left"
                    VerticalAlignment="Top"
                    Margin="8,8,0,0"
                    Background="#BB000000"
                    CornerRadius="4"
                    Padding="6,4">
                <TextBlock Text="{Binding PerfOverlayText}"
                           FontSize="11"
                           FontFamily="Consolas,Courier New,monospace"
                           Foreground="#FFFFC800"
                           IsHitTestVisible="False"
                           AutomationProperties.Name="Performance statistics overlay" />
            </Border>

            <!-- Nearby chat overlay (bottom-left, shown when ShowChatOverlay is true) -->
            <Border IsHitTestVisible="False"
                    IsVisible="{Binding ShowChatOverlay}"
                    HorizontalAlignment="Left"
                    VerticalAlignment="Bottom"
                    Margin="8,0,0,8"
                    Background="#BB000000"
                    CornerRadius="4"
                    Padding="6,4"
                    MaxWidth="480">
                <ItemsControl ItemsSource="{Binding ChatOverlayLines}"
                              IsHitTestVisible="False"
                              AutomationProperties.Name="Nearby chat overlay">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate x:DataType="vm:ChatLine">
                            <TextBlock FontSize="11"
                                       FontFamily="Segoe UI,Arial,sans-serif"
                                       Foreground="White"
                                       TextWrapping="Wrap"
                                       IsHitTestVisible="False"
                                       Text="{Binding AutomationText}" />
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </Border>

            <!-- Name-tag overlay: items positioned by the VM at avatar screen coords -->
            <Canvas IsHitTestVisible="False"
                    HorizontalAlignment="Stretch"
                    VerticalAlignment="Stretch">
                <ItemsControl ItemsSource="{Binding NameTags}"
                              IsHitTestVisible="False">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <Canvas IsHitTestVisible="False" />
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate x:DataType="rendering:NameTagItem">
                            <Border Canvas.Left="{Binding X}"
                                    Canvas.Top="{Binding Y}"
                                    Background="#99000000"
                                    CornerRadius="3"
                                    Padding="4,1">
                                <TextBlock Text="{Binding Name}"
                                           FontSize="11"
                                           Foreground="White" />
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                <!-- Prim hover-text overlay (within 12 m of camera) -->
                <ItemsControl ItemsSource="{Binding HoverTags}"
                              IsHitTestVisible="False">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <Canvas IsHitTestVisible="False" />
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate x:DataType="rendering:HoverTextItem">
                            <Border Canvas.Left="{Binding X}"
                                    Canvas.Top="{Binding Y}"
                                    Background="#AA000000"
                                    CornerRadius="3"
                                    Padding="4,2">
                                <TextBlock Text="{Binding Text}"
                                           FontSize="11"
                                           Foreground="{Binding Color, Converter={x:Static conv:ArgbToColorConverter.Instance}}"
                                           TextAlignment="Center"
                                           TextWrapping="Wrap" />
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </Canvas>
        </Grid>

    </DockPanel>
</UserControl>

